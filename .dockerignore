# Ignore version control
.git
.gitignore

# Ignore editor/project files
.vscode
.idea
*.swp
*.swo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore build artifacts
bin/
*.exe
*.out
*.test

# Ignore dependency folders
node_modules/

# Ignore Go build cache
*.mod
*.sum

# Ignore Docker artifacts
*.tar

# Ignore frontend build outputs (if any)
dist/
build/

# Ignore sensitive files
.env
.env.*
